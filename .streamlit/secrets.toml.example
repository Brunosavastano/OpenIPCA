# OpenIPCA — example Streamlit secrets file.
# Copy to ".streamlit/secrets.toml" and fill in your own values.
# NEVER commit the real "secrets.toml" (it is git-ignored).
#
# For the public "Ask the IPCA" demo, set the free Gemini provider here on the
# deploy (e.g. Streamlit Community Cloud secrets) — the key stays server-side.

OPENIPCA_AI_ENABLED = false
OPENIPCA_AI_PROVIDER = "none"
OPENIPCA_AI_MODEL = ""
ANTHROPIC_API_KEY = ""
OPENAI_API_KEY = ""
GOOGLE_API_KEY = ""

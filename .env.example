# OpenIPCA — example environment file.
# Copy to ".env" and fill in your own values. NEVER commit the real ".env".
# The app works fully WITHOUT AI; these are only needed to enable AI briefs locally.

# Master switch for the optional AI layer (default: false).
OPENIPCA_AI_ENABLED=false

# Provider name when AI is enabled. "none" uses the deterministic fallback.
# Any other value must match a provider registered in the provider registry —
# OpenIPCA is model-agnostic and does not privilege any vendor.
OPENIPCA_AI_PROVIDER=none

# Bring Your Own Key (only read when AI is enabled). Set the variable your chosen
# provider expects. Optionally pin the model for reproducibility — any model name
# the provider accepts works (OpenIPCA does not hard-code a model list).
# OPENIPCA_AI_MODEL=
# <PROVIDER>_API_KEY=
#
# Two providers ship in the optional extra (install with: pip install '.[ai]').
# The examples below are illustrative, not an endorsement:
#
# OpenAI (e.g. gpt-5.5, gpt-5.4, gpt-5.4-mini):
#   OPENIPCA_AI_ENABLED=true
#   OPENIPCA_AI_PROVIDER=openai
#   OPENIPCA_AI_MODEL=gpt-5.4
#   OPENAI_API_KEY=your-openai-key
#
# Anthropic (e.g. claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5):
#   OPENIPCA_AI_ENABLED=true
#   OPENIPCA_AI_PROVIDER=anthropic
#   OPENIPCA_AI_MODEL=claude-sonnet-4-6
#   ANTHROPIC_API_KEY=your-anthropic-key
#
# Google Gemini (free tier — used by the public "Ask the IPCA" demo):
#   OPENIPCA_AI_ENABLED=true
#   OPENIPCA_AI_PROVIDER=gemini
#   OPENIPCA_AI_MODEL=gemini-2.0-flash
#   GOOGLE_API_KEY=your-google-key

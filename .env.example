# OpenIPCA — example environment file.
# Copy to ".env" and fill in your own values. NEVER commit the real ".env".
# The app works fully WITHOUT AI; these are only needed to enable AI briefs locally.

# Master switch for the optional AI layer (default: false).
OPENIPCA_AI_ENABLED=false

# Which provider to use when AI is enabled: none | anthropic | openai
OPENIPCA_AI_PROVIDER=none

# Bring Your Own Key (only read when AI is enabled). Leave empty otherwise.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

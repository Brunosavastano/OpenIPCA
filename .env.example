# OpenIPCA — example environment file.
# Copy to ".env" and fill in your own values. NEVER commit the real ".env".
# The app works fully WITHOUT AI; these are only needed to enable AI briefs locally.

# Master switch for the optional AI layer (default: false).
OPENIPCA_AI_ENABLED=false

# Provider name when AI is enabled. "none" uses the deterministic fallback.
# Any other value must match a provider registered in the provider registry —
# OpenIPCA is model-agnostic and does not privilege any vendor.
OPENIPCA_AI_PROVIDER=none

# Bring Your Own Key (only read when AI is enabled). Set the variable your chosen
# provider expects; the example below is illustrative, not an endorsement.
# Optionally pin the model for reproducibility (provider-specific name).
# OPENIPCA_AI_MODEL=
# <PROVIDER>_API_KEY=
#
# Example for the bundled "openai" provider (install with: pip install '.[ai]'):
#   OPENIPCA_AI_ENABLED=true
#   OPENIPCA_AI_PROVIDER=openai
#   OPENAI_API_KEY=your-key-here
